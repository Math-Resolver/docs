      "text": "Collection EquationHistory\n{\n    username: \"user@mail.com\",\n    Equation: \"2*x + 5 = 15\",\n    Result: \"x=5\",\n    Steps: \n        [\n            {\n              \"rule\": \"subtrair 5 dos dois lados\",\n              \"before\": \"2x + 5 = 15\",\n              \"after\": \"2x = 10\"\n            },\n            {\n              \"rule\": \"dividir por 2\",\n              \"before\": \"2x = 10\",\n              \"after\": \"x = 5\"\n            } \n        ],\n    \"createdAt\": today\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Collection EquationHistory\n{\n    username: \"user@mail.com\",\n    Equation: \"2*x + 5 = 15\",\n    Result: \"x=5\",\n    Steps: \n        [\n            {\n              \"rule\": \"subtrair 5 dos dois lados\",\n              \"before\": \"2x + 5 = 15\",\n              \"after\": \"2x = 10\"\n            },\n            {\n              \"rule\": \"dividir por 2\",\n              \"before\": \"2x = 10\",\n              \"after\": \"x = 5\"\n            } \n        ],\n    \"createdAt\": today\n}",
