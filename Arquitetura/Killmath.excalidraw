      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[\n    {\n      \"equation\": \"2*x + 5 = 15\"\n      \"result\": \"x = 5\",\n      \"steps\": [\n        {\n          \"rule\": \"subtrair 5 dos dois lados\",\n          \"before\": \"2x + 5 = 15\",\n          \"after\": \"2x = 10\"\n        },\n        {\n          \"rule\": \"dividir por 2\",\n          \"before\": \"2x = 10\",\n          \"after\": \"x = 5\"\n        }\n      ]\n    },\n    {\n      \"equation\": \"2*x + 5 = 15\",\n      \"result\": \"x = 5\",\n      \"steps\": [\n        {\n          \"rule\": \"subtrair 5 dos dois lados\",\n          \"before\": \"2x + 5 = 15\",\n          \"after\": \"2x = 10\"\n        },\n        {\n          \"rule\": \"dividir por 2\",\n          \"before\": \"2x = 10\",\n          \"after\": \"x = 5\"\n        }\n      ]\n    },..\n]",
