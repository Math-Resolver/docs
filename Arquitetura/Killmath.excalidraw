    {
      "id": "dDL2DJwKQ9Z7IHSHFhEB6",
      "type": "text",
      "x": 263.41219170331595,
      "y": 1090.7726956187619,
      "width": 299.79168701171875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
