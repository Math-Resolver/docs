      "lineHeight": 1.25
    },
    {
      "id": "6FeD5ZOUbvZjTkUqD3YD4",
      "type": "text",
      "x": 480.7802734375,
      "y": 299.8000183105469,
      "width": 734.439453125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
