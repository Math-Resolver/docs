      "roundness": null,
      "seed": 1499272143,
      "version": 150,
      "versionNonce": 1115475279,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773200717748,
      "link": null,
      "locked": false,
      "text": "{\n  \"result\": \"x = 5\",\n  \"steps\": [\n    {\n      \"rule\": \"subtrair 5 dos dois lados\",\n      \"before\": \"2x + 5 = 15\",\n      \"after\": \"2x = 10\"\n    },\n    {\n      \"rule\": \"dividir por 2\",\n      \"before\": \"2x = 10\",\n      \"after\": \"x = 5\"\n    }\n  ]\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "{\n  \"result\": \"x = 5\",\n  \"steps\": [\n    {\n      \"rule\": \"subtrair 5 dos dois lados\",\n      \"before\": \"2x + 5 = 15\",\n      \"after\": \"2x = 10\"\n    },\n    {\n      \"rule\": \"dividir por 2\",\n      \"before\": \"2x = 10\",\n      \"after\": \"x = 5\"\n    }\n  ]\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
