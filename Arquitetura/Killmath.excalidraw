      "text": "Projeto: Criar um aplicativo que é capaz de resolver equações matemáticas\nsimples ou complexas",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Projeto: Criar um aplicativo que é capaz de resolver equações matemáticas simples ou complexas",
